#jinja2: keep_trailing_newline: True
[Trigger]
Type = Package
Operation = Upgrade
Target = pacman-mirrorlist

[Action]
Description = Updating /etc/pacman.d/mirrorlist
When = PostTransaction
Exec = /usr/bin/sh -c "if [ -f /etc/pacman.d/mirrorlist.pacnew ]; then sed -i 's/## Worldwide/Server = https:\/\/geo.mirror.pkgbuild.com\/\$repo\/os\/\$arch\n\n## Worldwide/1' /etc/pacman.d/mirrorlist.pacnew && mv /etc/pacman.d/mirrorlist.pacnew /etc/pacman.d/mirrorlist; fi"
